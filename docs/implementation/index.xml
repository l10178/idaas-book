│ ┌───────────────────────────┴──────────────────────────────┐ │
│ │ Infinispan (缓存层) │ │
│ │ ┌────────────┐ ┌────────────┐ ┌──────────────────┐ │ │
│ │ │User Cache │ │Realm Cache │ │Auth Session Cache│ │ │
│ │ └────────────┘ └────────────┘ └──────────────────┘ │ │
│ └───────────────────────────┬──────────────────────────────┘ │
│ │ │
│ ┌───────────────────────────┴──────────────────────────────┐ │
